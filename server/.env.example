# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Database
MONGODB_URI=mongodb://127.0.0.1:27017/manjus_atelier

# Auth
JWT_SECRET=replace_with_a_long_random_secret_string
JWT_EXPIRES_IN=7d
COOKIE_SECRET=replace_with_another_long_random_secret


# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Email / ImprovMX SMTP Configuration
SMTP_HOST=smtp.improvmx.com
SMTP_PORT=587
SMTP_USER=your_improvmx_email_user
SMTP_PASS=your_improvmx_smtp_password
EMAIL_FROM=help@manjusatelier.in
FROM_NAME=Manju's Atelier
